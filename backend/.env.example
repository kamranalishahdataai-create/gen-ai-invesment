# GenAI Investment Learning Platform - Environment Variables
# =========================================================
# Copy this file to .env and fill in your API keys

# OpenAI API Key (Required for AI-generated content)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your-openai-api-key-here

# Gold Price API (Required for real gold prices)
# Get a free key from: https://www.goldapi.io/
# Note: Key must start with "goldapi-" prefix
GOLD_API_KEY=goldapi-your-key-here

# ElevenLabs API Key (Required for text-to-speech audio)
# Get from: https://elevenlabs.io/
# Note: Free tier has 10K chars/month, Starter plan has 40K chars/month
ELEVENLABS_API_KEY=sk_your-elevenlabs-key-here

# AIML API Key (Optional - for Kling AI video generation)
# Get from: https://aimlapi.com/
# Generates 5-10 second video clips
AIML_API_KEY=your-aiml-key-here

# Vadoo AI API Key (Optional - for full video generation)
# Get from: https://ai.vadoo.tv/profile
# Generates 30sec to 10min videos with voiceover and captions
VADOO_API_KEY=your-vadoo-key-here

# Server Configuration
HOST=127.0.0.1
PORT=8000
